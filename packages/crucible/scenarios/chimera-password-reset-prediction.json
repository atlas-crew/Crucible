{
  "id": "chimera-password-reset-prediction",
  "name": "Chimera Password Reset Token Prediction",
  "category": "Broken Authentication",
  "difficulty": "Advanced",
  "description": "Exploits predictable password reset tokens in Chimera by requesting resets, observing leaked tokens, and attempting to use predicted or stolen tokens to hijack accounts.",
  "tags": [
    "chimera",
    "password-reset",
    "token-prediction",
    "owasp-a07"
  ],
  "steps": [
    {
      "id": "request-reset",
      "name": "Request Password Reset for Admin",
      "stage": "reconnaissance",
      "request": {
        "method": "POST",
        "url": "/api/v1/auth/forgot-password",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "admin@example.com"
        }
      },
      "execution": {
        "delayMs": 500
      },
      "expect": {
        "status": 200
      },
      "extract": {
        "reset_token": {
          "from": "body",
          "path": "reset_token"
        }
      }
    },
    {
      "id": "enumerate-user-exists",
      "name": "Enumerate User Existence via Reset Timing",
      "stage": "reconnaissance",
      "request": {
        "method": "POST",
        "url": "/api/v1/auth/forgot-password",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "nonexistent@example.com"
        }
      },
      "execution": {
        "delayMs": 500
      },
      "expect": {
        "status": 200
      },
      "dependsOn": [
        "request-reset"
      ]
    },
    {
      "id": "reset-with-leaked-token",
      "name": "Reset Password Using Leaked Token",
      "stage": "exploitation",
      "request": {
        "method": "POST",
        "url": "/api/v1/auth/reset-password",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "reset_token": "{{reset_token}}",
          "new_password": "hacked123!"
        }
      },
      "execution": {
        "delayMs": 500
      },
      "expect": {
        "blocked": true
      },
      "dependsOn": [
        "request-reset"
      ]
    },
    {
      "id": "reset-with-predictable-token",
      "name": "Reset Password Using Predictable Token",
      "stage": "exploitation",
      "request": {
        "method": "POST",
        "url": "/api/v1/auth/reset-password",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "reset_token": "predictable-md5-token",
          "new_password": "hacked123!"
        }
      },
      "execution": {
        "delayMs": 500
      },
      "expect": {
        "blocked": true
      },
      "dependsOn": [
        "enumerate-user-exists"
      ]
    }
  ]
}
