---
layout: null
---
[
  {% for page in site.pages %}{% if page.url contains '.html' and page.title %}
  {
    "title": {{ page.title | jsonify }},
    "url": "{{ page.url | relative_url }}",
    "content": {{ page.content | strip_html | truncatewords: 200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endif %}{% endfor %}
]
